# ─────────────────────────────────────────────
# Excelater — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ─────────────────────────────────────────────

# ── Servidor ──────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Base de datos y logs ──────────────────────
DB_PATH=scheduler.db
LOGS_DIR=logs

# ── Autenticación ─────────────────────────────
# Dejar vacío para deshabilitar la autenticación.
# Si se configura, todas las peticiones a /api deben incluir:
#   Header:      X-API-Key: <valor>
#   Query param: ?api_key=<valor>
API_KEY=

# ── Notificaciones webhook ────────────────────
# URL a la que se enviará un POST JSON tras cada ejecución.
# Dejar vacío para deshabilitar.
WEBHOOK_URL=
NOTIFY_ON_FAILURE=true
NOTIFY_ON_SUCCESS=false

# ── Timezone ──────────────────────────────────
# Zona horaria para el scheduler (formato IANA).
# Ejemplos: America/Lima, America/Bogota, America/Mexico_City, Europe/Madrid
TIMEZONE=America/Lima

# ── Retry automático ──────────────────────────
# Número máximo de reintentos globales (0 = sin retry).
RETRY_MAX=0
RETRY_DELAY_S=60

# ── CORS ──────────────────────────────────────
# Orígenes permitidos, separados por coma.
# Usar * para permitir todos (no recomendado en producción).
CORS_ORIGINS=*

# ── Límites de Excel ──────────────────────────
LOCK_TIMEOUT_S=120
LOCK_RETRY_S=5
LOCK_MAX_RETRIES=5   # 0 = sin límite, usar solo el timeout
REFRESH_TIMEOUT_S=300
REFRESH_CHECK_S=3

# ── Email SMTP ────────────────────────────────
# Dejar SMTP_HOST vacío para deshabilitar notificaciones por email.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=servicioti@thebox.com.pe
SMTP_PASSWORD=$erVici0sTi$
# Dirección que aparecerá como remitente. Si está vacío, se usa SMTP_USER.
SMTP_FROM=Excelater <servicioti@thebox.com.pe>
SMTP_TLS=true

# ── Logs de tareas ────────────────────────────
MAX_LOG_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ── Navegador de archivos remoto ──────────────
# Cuando alguien usa la app desde otra maquina de la red, el dialogo nativo
# de Windows no puede aparecer en su pantalla (se dibujaria en el host).
# Para esos casos, define aqui las carpetas que pueden navegarse desde la UI.
# Solo admin/superuser pueden usar este navegador. Si dejas la lista vacia,
# el navegador remoto queda deshabilitado (clientes locales siguen usando
# el dialogo nativo).
#
# Formato: JSON con objetos {label, path}. Usa doble backslash en Windows.
# Soporta UNC paths (\\\\server\\share).
#
# Ejemplo:
# FS_BROWSE_ROOTS=[{"label":"OneDrive","path":"C:\\Users\\luis\\OneDrive"},{"label":"Datos","path":"D:\\Datos"},{"label":"FileServer","path":"\\\\fileserver\\reportes"}]
FS_BROWSE_ROOTS=

# Mostrar archivos/carpetas ocultas en el navegador remoto (no recomendado).
FS_BROWSE_ALLOW_HIDDEN=false
